###############################################################################
# Set default behavior to automatically normalize line endings.
###############################################################################

#note left to system settings
*	text=auto

###############################################################################
# Scripts
###############################################################################

# We dont want CRLF for bash shell scripts
*.sh    text eol=lf


###############################################################################
# DFINITY/Motoko
###############################################################################

*.mo    text eol=lf

###############################################################################
# Yaml
###############################################################################


*.yml   text eol=lf
*.yaml  text eol=lf

###############################################################################
# C#
###############################################################################

*.cs    text=auto diff=csharp

###############################################################################
# Preserve existing line endings for markdown files that were originally CRLF
###############################################################################

# CHANGELOG.md was committed with CRLF line endings; treat as binary to
# preserve CRLF so that diffs remain content-only (not mixed with CRLF→LF noise)
CHANGELOG.md -text

###############################################################################
# Explicitly binary - should be handled automatically anyway
###############################################################################
*.jpg   binary
*.jpeg  binary
*.png   binary
*.gif   binary
*.ico   binary
*.woff  binary
*.wof   binary
*.eot   binary
*.ttf   binary
